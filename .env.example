# Krónan API — get your token at https://kronan.is (Settings → Access Tokens)
# Requires an Icelandic electronic ID (Auðkenni) to create
KRONAN_API_KEY=act_your_token_here

# Anthropic API — get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Slack Bot (optional — only needed if running the Slack bot)
# See docs/slackbot-setup.md for how to create these
SLACK_BOT_TOKEN=xoxb-your_token_here
SLACK_APP_TOKEN=xapp-your_token_here

# Model override (optional — default is claude-sonnet-4-6)
# CROWNAN_MODEL=claude-sonnet-4-6
